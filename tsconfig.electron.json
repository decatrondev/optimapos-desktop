{
    "compilerOptions": {
        "target": "ES2020",
        "module": "CommonJS",
        "lib": [
            "ES2020"
        ],
        "skipLibCheck": true,
        "moduleResolution": "node",
        "outDir": "dist-electron",
        "rootDir": "electron",
        "strict": true,
        "esModuleInterop": true,
        "resolveJsonModule": true,
        "declaration": false,
        "noUnusedLocals": false,
        "noUnusedParameters": false
    },
    "include": [
        "electron/**/*.ts"
    ]
}